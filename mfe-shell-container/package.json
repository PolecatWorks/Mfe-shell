    "@angular/build": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.3",
    "@vitest/browser-playwright": "^4.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.1.0",
    "playwright": "^1.49.0",
